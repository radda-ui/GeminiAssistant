[
    {
        "caption": "GeminiAssistant: Ask Gemini",
        "command": "gemini_code_assistant"
    },
    {
        "caption": "GeminiAssistant: New Conversation",
        "command": "gemini_new_conversation"
    },
    {
        "caption": "GeminiAssistant: Open Conversation",
        "command": "gemini_open_conversation"
    },
    {
        "caption": "GeminiAssistant: Delete Conversation",
        "command": "gemini_delete_conversation"
    },
    {
        "caption": "GeminiAssistant: Copy Last Response",
        "command": "gemini_copy_last_response"
    },
    { "caption": "-" },
    {
        "caption": "Preferences: GeminiAssistant Settings",
        "command": "edit_settings",
        "args": {
            "base_file": "${packages}/GeminiAssistant/Gemini Assistant.sublime-settings",
            "default": "{\n\t$0\n}\n"
        }
    },
    {
        "caption": "Preferences: GeminiAssistant Key Bindings",
        "command": "edit_settings",
        "args": {
            "base_file": "${packages}/GeminiAssistant/Default  ($platform).sublime-keymap",
            "default": "[\n\t$0\n]\n"
        }
    },
    {
        "caption": "GeminiAssistant: Open Readme",
        "command": "open_file",
        "args": {
            "file": "${packages}/GeminiAssistant/README.md"
        }
    }
]
